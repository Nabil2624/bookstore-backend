{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "strict": true,

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,

    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "noEmit": true,

    "types": ["node", "vitest/globals"]
  },

  "include": [
  "src",
  "tests",
  "eslint.config.mjs",
  "vitest.config.ts"
],

  "exclude": ["node_modules"]
}